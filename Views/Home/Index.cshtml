@{
    ViewData["Title"] = "Hệ thống kiểm tra nhiệt độ";
}

<div class="temp-page">
    <section class="temp-hero">
        <div class="temp-logo">
            <img src="/images/logodrb.png" alt="DRB Vietnam" />
        </div>

        <div class="temp-title">
            <h1>HỆ THỐNG KIỂM TRA NHIỆT ĐỘ & ĐỘ ẨM</h1>
            <span></span>
        </div>

        <div class="temp-update">
            <div>
                <small>Cập nhật lúc:</small>
                <strong id="updateTime">--</strong>
            </div>
            <i class="fa-solid fa-expand" id="fullscreenBtn"></i>
            <b></b>
        </div>
    </section>

    <section class="temp-content-grid">
        <article class="summary-combo current-box current-main" id="currentMetric">
            <div class="summary-top">
                <h3><i class="fa-regular fa-clock"></i> NHIỆT ĐỘ HIỆN TẠI</h3>
            </div>

            <div class="current-vertical">
                <div class="current-item temperature">
                    <div class="metric-icon">
                        <p>NHIỆT ĐỘ</p>
                        <i class="fa-solid fa-temperature-three-quarters"></i>
                    </div>

                    <div class="current-info">
                        <strong><span id="currentTemp">--</span><small>°C</small></strong>
                    </div>
                </div>

                <div class="current-line"></div>

                <div class="current-item humidity">
                    <div class="metric-icon">
                        <p>ĐỘ ẨM</p>
                        <i class="fa-solid fa-droplet"></i>
                    </div>

                    <div class="current-info">
                        <strong><span id="currentHum">--</span><small>%</small></strong>
                    </div>
                </div>
            </div>
        </article>

        <div class="right-panels">
            <article class="summary-combo today-box" id="todayMetric">
                <div class="summary-top">
                    <h3>
                        <i class="fa-regular fa-calendar-days"></i>
                        NHIỆT ĐỘ CAO NHẤT TRONG NGÀY
                    </h3>

                    <div class="summary-time">
                        <i class="fa-regular fa-clock"></i>
                        <span>
                            Cập nhật lúc:
                            <b id="todayUpdateTime">--</b>
                        </span>
                    </div>
                </div>

                <div class="summary-row">
                    <div class="metric-item temperature">
                        <div class="metric-icon">
                            <i class="fa-solid fa-temperature-three-quarters"></i>
                        </div>

                        <div>
                            <p>NHIỆT ĐỘ</p>
                            <strong><span id="todayTemp">--</span>°C</strong>
                        </div>
                    </div>

                    <div class="metric-divider"></div>

                    <div class="metric-item humidity">
                        <div class="metric-icon">
                            <i class="fa-solid fa-droplet"></i>
                        </div>

                        <div>
                            <p>ĐỘ ẨM</p>
                            <strong><span id="todayHum">--</span>%</strong>
                        </div>
                    </div>
                </div>
            </article>

            <article class="dash-panel day-panel">
                <div class="panel-head simple">
                    <h2>
                        <i class="fa-solid fa-temperature-three-quarters"></i>
                        KẾT QUẢ NHIỆT ĐỘ 7 NGÀY QUA
                    </h2>
                </div>

                <div class="day-list" id="tempDays"></div>
            </article>

            <article class="dash-panel chart-panel">
                <div class="panel-head">
                    <h2>
                        <i class="fa-solid fa-chart-line"></i>
                        BIẾN ĐỘNG NHIỆT ĐỘ TRONG NGÀY
                    </h2>

                    <div class="intraday-peak" id="intradayPeak">
                        <i class="fa-solid fa-fire"></i>
                        Cao nhất: <strong id="peakValue">--</strong>°C lúc <strong id="peakTime">--</strong>
                    </div>
                </div>

                <div class="chart-box">
                    <canvas id="tempChart"></canvas>
                </div>
            </article>
        </div>
    </section>

    <section class="dash-panel month-panel">
        <div class="month-head">
            <h2>
                <i class="fa-regular fa-calendar-days"></i>
                KẾT QUẢ NHIỆT ĐỘ TRONG THÁNG
            </h2>

            <div class="month-actions">
                <button type="button" id="exportExcelBtn" class="export-excel-btn">
                    <i class="fa-regular fa-file-excel"></i>
                    Xuất Excel
                </button>

                <button type="button" id="prevMonthBtn">‹</button>

                <span id="currentMonthLabel">
                    <i class="fa-regular fa-calendar-days"></i> --
                </span>

                <button type="button" id="nextMonthBtn">›</button>
            </div>
        </div>

        <div class="month-scroll">
            <div class="month-table" id="monthTable"></div>
        </div>

        <p class="unit-note">
            Đơn vị: °C - Nhiệt độ trung bình. Nhiệt độ từ 38.0°C trở lên hiển thị màu đỏ.
        </p>
    </section>
</div>

<script>
    const warningTemp = 38;

    let labels = [];
    let days = [];
    let tempData = [];
    let monthValues = [];

    let intradayTimes = [];
    let intradayTemps = [];

    let isRealtimeLoading = false;
    let lastTemp = null;
    let lastHum = null;

    const currentDate = new Date();
    let selectedYear = currentDate.getFullYear();
    let selectedMonth = currentDate.getMonth();

    function isHot(value) {
        return value >= warningTemp;
    }

    function setText(id, value) {
        const el = document.getElementById(id);

        if (el && el.textContent !== value) {
            el.textContent = value;
        }
    }

    function getTotalDaysInSelectedMonth() {
        return new Date(selectedYear, selectedMonth + 1, 0).getDate();
    }

    function formatSelectedMonthLabel() {
        const monthText = String(selectedMonth + 1).padStart(2, "0");
        return `${monthText}/${selectedYear}`;
    }

    function formatSelectedDate(day) {
        const dayText = String(day).padStart(2, "0");
        const monthText = String(selectedMonth + 1).padStart(2, "0");
        return `${dayText}/${monthText}`;
    }

    function setCurrentMonthLabel() {
        const el = document.getElementById("currentMonthLabel");

        if (el) {
            el.innerHTML = `<i class="fa-regular fa-calendar-days"></i> Tháng ${formatSelectedMonthLabel()}`;
        }
    }

    function isSelectedDayFuture(day) {
        const selectedDate = new Date(selectedYear, selectedMonth, day);
        const today = new Date();

        selectedDate.setHours(0, 0, 0, 0);
        today.setHours(0, 0, 0, 0);

        return selectedDate > today;
    }

    async function loadRealtimeData() {
        if (isRealtimeLoading) return;

        isRealtimeLoading = true;

        try {
            const response = await fetch('/GetData', {
                method: 'GET',
                cache: 'no-store'
            });

            const data = await response.json();

            if (!data || data.success !== true) {
                return;
            }

            const temp = parseFloat(data.nhietDo);
            const hum = parseFloat(data.doAm);

            if (isNaN(temp) || isNaN(hum)) {
                return;
            }

            const tempText = temp.toFixed(1);
            const humText = hum.toString();

            if (lastTemp !== tempText) {
                setText("currentTemp", tempText);
                lastTemp = tempText;
            }

            if (lastHum !== humText) {
                setText("currentHum", humText);
                lastHum = humText;
            }

            document
                .getElementById("currentMetric")
                ?.classList.toggle("danger", temp >= warningTemp);

            const now = new Date();

            const currentTime =
                now.toLocaleDateString("vi-VN") +
                " " +
                now.toLocaleTimeString("vi-VN");

            setText("updateTime", currentTime);

            await loadIntradayTemperature();

            if (data.dailyLogSaved === true) {
                await loadTodaySavedMetric();
                await loadLast7DaysTemperature();

                const today = new Date();
                const isViewingCurrentMonth =
                    selectedYear === today.getFullYear() &&
                    selectedMonth === today.getMonth();

                if (isViewingCurrentMonth) {
                    await loadCurrentMonthTemperature();
                }
            }
        }
        catch (error) {
            console.error(error);
        }
        finally {
            isRealtimeLoading = false;
        }
    }

    async function loadTodaySavedMetric() {
        try {
            const response = await fetch('/GetLatestDailyLog', {
                method: 'GET',
                cache: 'no-store'
            });

            const result = await response.json();

            if (!result || result.success !== true || !result.data) {
                setText("todayTemp", "--");
                setText("todayHum", "--");
                setText("todayUpdateTime", "--");
                return;
            }

            const temp = Number(result.data.nhietDo ?? 0);
            const hum = Number(result.data.doAm ?? 0);

            setText("todayTemp", temp.toFixed(1));
            setText("todayHum", hum.toFixed(1));
            setText("todayUpdateTime", result.data.updateTime ?? "--");

            document
                .getElementById("todayMetric")
                ?.classList.toggle("danger", temp >= warningTemp);
        }
        catch (error) {
            console.error(error);
        }
    }

    async function loadLast7DaysTemperature() {
        try {
            const response = await fetch('/GetLast7DaysTemperature', {
                method: 'GET',
                cache: 'no-store'
            });

            const result = await response.json();

            labels = [];
            days = [];
            tempData = [];

            if (!result || result.success !== true || !Array.isArray(result.data)) {
                for (let i = 0; i < 7; i++) {
                    labels.push("--");
                    days.push("--");
                    tempData.push(0);
                }

                renderDayCards();
                drawChart();
                return;
            }

            result.data.forEach(item => {
                labels.push(item.date ?? "--");
                days.push(item.dayName ?? "--");
                tempData.push(Number(item.value ?? 0));
            });

            while (labels.length < 7) {
                labels.push("--");
                days.push("--");
                tempData.push(0);
            }

            renderDayCards();
            drawChart();
        }
        catch {
            labels = [];
            days = [];
            tempData = [];

            for (let i = 0; i < 7; i++) {
                labels.push("--");
                days.push("--");
                tempData.push(0);
            }

            renderDayCards();
            drawChart();
        }
    }

    async function loadIntradayTemperature() {
        try {
            const response = await fetch('/GetTodayIntradayTemperature', {
                method: 'GET',
                cache: 'no-store'
            });

            const result = await response.json();

            intradayTimes = [];
            intradayTemps = [];

            if (result && result.success === true && Array.isArray(result.data)) {
                result.data.forEach(item => {
                    const val = Number(item.nhietDo ?? 0);
                    intradayTimes.push(item.time ?? "--");
                    intradayTemps.push(val > 0 ? val : null);
                });
            }

            const peakVal = result?.peakValue ?? 0;
            const peakTime = result?.peakTime ?? "--";

            const peakEl = document.getElementById("intradayPeak");
            if (peakEl) {
                peakEl.classList.toggle("danger", peakVal >= warningTemp);
            }

            document.getElementById("peakValue") && (document.getElementById("peakValue").textContent = peakVal > 0 ? peakVal.toFixed(1) : "--");
            document.getElementById("peakTime") && (document.getElementById("peakTime").textContent = peakTime);

            if (intradayTemps.length === 0) return;

            if (!window.tempLineChart) {
                drawIntradayChart();
            } else {
                window.tempLineChart.data.labels = intradayTimes;
                window.tempLineChart.data.datasets[0].data = intradayTemps;
                window.tempLineChart.data.datasets[1].data = intradayTimes.map(() => warningTemp);
                window.tempLineChart.update("none");
            }
        }
        catch (error) {
            console.error(error);
        }
    }

    function drawIntradayChart() {
        const canvas = document.getElementById("tempChart");

        if (!canvas) return;

        if (window.tempLineChart) {
            window.tempLineChart.destroy();
        }

        const ctx = canvas.getContext("2d");

        const pointColors = intradayTemps.map(v =>
            v >= warningTemp ? "#e11d1d" : "#0f9f59"
        );

        window.tempLineChart = new Chart(ctx, {
            type: "line",
            data: {
                labels: intradayTimes,
                datasets: [
                    {
                        label: "Nhiệt độ (°C)",
                        data: intradayTemps,
                        borderColor: "#3b82f6",
                        backgroundColor: "transparent",
                        borderWidth: 1.5,
                        fill: false,
                        tension: 0,
                        spanGaps: false,
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        segment: {
                            borderColor: ctx => {
                                const y1 = ctx.p0.parsed.y;
                                const y2 = ctx.p1.parsed.y;
                                return (y1 >= warningTemp || y2 >= warningTemp) ? "#e11d1d" : "#3b82f6";
                            }
                        }
                    },
                    {
                        label: "Ngưỡng " + warningTemp + "°C",
                        data: intradayTimes.map(() => warningTemp),
                        borderColor: "#e11d1d",
                        borderWidth: 1.5,
                        pointRadius: 0,
                        fill: false,
                        animation: false
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: false,
                interaction: {
                    mode: "index",
                    intersect: false
                },
                plugins: {
                    legend: {
                        position: "bottom",
                        labels: {
                            usePointStyle: true,
                            boxWidth: 8,
                            padding: 14,
                            font: { size: 12, weight: "bold" },
                            color: "#334155"
                        }
                    },
                    tooltip: {
                        backgroundColor: "#07142f",
                        titleColor: "#ffffff",
                        bodyColor: "#ffffff",
                        padding: 10,
                        cornerRadius: 8,
                        displayColors: true,
                        filter: item => item.datasetIndex === 0,
                        callbacks: {
                            label: item => Number(item.raw).toFixed(1) + "°C"
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: "#f1f5f9" },
                        ticks: {
                            color: "#475569",
                            font: { size: 10 },
                            maxRotation: 0,
                            autoSkip: true,
                            maxTicksLimit: 10
                        }
                    },
                    y: {
                        min: 0,
                        max: 50,
                        ticks: {
                            stepSize: 10,
                            color: "#475569",
                            font: { size: 11 },
                            callback: v => v + "°C"
                        },
                        grid: { color: "#e2e8f0" }
                    }
                }
            }
        });
    }

    async function loadCurrentMonthTemperature() {
        try {
            setCurrentMonthLabel();

            const monthQuery = selectedMonth + 1;

            const response = await fetch(`/GetCurrentMonthTemperature?year=${selectedYear}&month=${monthQuery}`, {
                method: 'GET',
                cache: 'no-store'
            });

            const result = await response.json();

            monthValues = [];

            const totalDays = getTotalDaysInSelectedMonth();
            const dataMap = new Map();

            if (result && result.success === true && Array.isArray(result.data)) {
                result.data.forEach(item => {
                    const day = Number(item.day ?? 0);

                    if (day > 0) {
                        dataMap.set(day, item);
                    }
                });
            }

            for (let day = 1; day <= totalDays; day++) {
                const item = dataMap.get(day);
                const rawValue = item ? item.value : null;
                const isFutureDay = isSelectedDayFuture(day);

                const hasValue =
                    !isFutureDay &&
                    rawValue !== null &&
                    rawValue !== undefined &&
                    rawValue !== "" &&
                    !isNaN(Number(rawValue));

                monthValues.push({
                    day: day,
                    date: item?.date ?? formatSelectedDate(day),
                    value: hasValue ? Number(rawValue) : null
                });
            }

            renderMonth();
        }
        catch (error) {
            console.error(error);
            monthValues = [];
            setCurrentMonthLabel();
            renderMonth();
        }
    }

    function renderDayCards() {
        const tempDays = document.getElementById("tempDays");

        if (!tempDays) return;

        let html = "";

        for (let index = 0; index < 7; index++) {
            const value = Number(tempData[index] ?? 0);
            const hot = isHot(value);

            html += `<div class="day-card ${hot ? "hot" : "normal"}">
                        <strong>${days[index] ?? "--"}</strong>
                        <small>${labels[index] ?? "--"}</small>
                        <b>${value.toFixed(1)}°C</b>
                    </div>`;
        }

        tempDays.innerHTML = html;
    }

    function renderMonth() {
        const monthTable = document.getElementById("monthTable");

        if (!monthTable) return;

        let html = "";

        if (!monthValues || monthValues.length === 0) {
            const totalDays = getTotalDaysInSelectedMonth();

            for (let i = 1; i <= totalDays; i++) {
                html += `<div class="month-cell">
                            <strong>${String(i).padStart(2, "0")}</strong>
                            <small>${formatSelectedDate(i)}</small>
                            <b>--</b>
                        </div>`;
            }

            monthTable.innerHTML = html;
            return;
        }

        const today = new Date();
        const isCurrentMonth =
            selectedYear === today.getFullYear() &&
            selectedMonth === today.getMonth();

        monthValues.forEach(item => {
            const value = item.value;
            const hasValue = value !== null && value !== undefined && !isNaN(value);
            const hot = hasValue && isHot(value);
            const isToday = isCurrentMonth && item.day === today.getDate();
            const dayText = String(item.day).padStart(2, "0");
            const valueText = hasValue ? value.toFixed(1) + "°C" : "--";

            html += `<div class="month-cell ${isToday ? "today" : ""} ${hot ? "hot" : ""}">
                        <strong>${dayText}</strong>
                        <small>${item.date}</small>
                        <b>${valueText}</b>
                    </div>`;
        });

        monthTable.innerHTML = html;
    }

    function drawChart() {
        // biểu đồ 7 ngày không còn dùng, giữ hàm rỗng để không lỗi call cũ
    }

    const fullscreenBtn = document.getElementById('fullscreenBtn');

    if (fullscreenBtn) {
        fullscreenBtn.addEventListener('click', () => {
            const elem = document.documentElement;

            if (!document.fullscreenElement) {
                elem.requestFullscreen().then(() => {
                    fullscreenBtn.classList.replace('fa-expand', 'fa-compress');
                }).catch(err => {
                    console.error(`Không thể bật full screen: ${err.message}`);
                });
            } else {
                document.exitFullscreen().then(() => {
                    fullscreenBtn.classList.replace('fa-compress', 'fa-expand');
                });
            }
        });
    }

    const exportExcelBtn = document.getElementById("exportExcelBtn");
    const prevMonthBtn = document.getElementById("prevMonthBtn");
    const nextMonthBtn = document.getElementById("nextMonthBtn");

    if (exportExcelBtn) {
        exportExcelBtn.addEventListener("click", function () {
            const monthQuery = selectedMonth + 1;

            window.location.href = `/ExportMonthTemperatureToExcel?year=${selectedYear}&month=${monthQuery}`;
        });
    }

    if (prevMonthBtn) {
        prevMonthBtn.addEventListener("click", async function () {
            selectedMonth--;

            if (selectedMonth < 0) {
                selectedMonth = 11;
                selectedYear--;
            }

            await loadCurrentMonthTemperature();
        });
    }

    if (nextMonthBtn) {
        nextMonthBtn.addEventListener("click", async function () {
            selectedMonth++;

            if (selectedMonth > 11) {
                selectedMonth = 0;
                selectedYear++;
            }

            await loadCurrentMonthTemperature();
        });
    }

    document.addEventListener("DOMContentLoaded", function () {
        loadRealtimeData();
        loadTodaySavedMetric();
        loadLast7DaysTemperature();
        loadCurrentMonthTemperature();
        loadIntradayTemperature();

        const intervals = [
            setInterval(loadRealtimeData, 1000),
            setInterval(loadTodaySavedMetric, 60000),
            setInterval(loadLast7DaysTemperature, 60000),
            setInterval(loadCurrentMonthTemperature, 60000)
        ];

        window.addEventListener("beforeunload", function () {
            intervals.forEach(id => clearInterval(id));

            if (window.tempLineChart) {
                window.tempLineChart.destroy();
                window.tempLineChart = null;
            }
        });
    });
</script>